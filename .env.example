# Copy this file to .env and fill in your keys. NEVER commit .env (it is gitignored).
#
# Default to the cheap/fast tier for everything - Haiku / Flash / Mini.
# Only step up to a bigger model if a group hits a real quality wall.

# Anthropic - suggested default model: claude-haiku-4-5
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# OpenAI - suggested default model: gpt-5-mini (fall back to gpt-4o-mini)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Google Gemini - suggested default model: gemini-2.5-flash
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Bring your own (optional) ---
# Add any other service a group has access to for the session - a legal-content
# API, a company-data API, an internal endpoint. See docs/EXTERNAL_APIS.md.
# Example shape:
# MY_API_BASE_URL=
# MY_API_TOKEN=
